# Supabase (Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=        # server-only secret; bypasses RLS

# AI providers — at least one required; the audit runs with whichever keys exist
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
PERPLEXITY_API_KEY=

# Inngest — the audit pipeline runs on Inngest.
# Local dev: leave blank and run `npx inngest-cli@latest dev`.
# Production: set both from the Inngest dashboard.
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Protects the cron endpoints (/api/queue/process, /api/monitoring/run).
# Generate: openssl rand -hex 32  — required in production.
CRON_SECRET=

# Stripe billing (checkout + webhook). Without these, checkout fails closed (503).
STRIPE_SECRET_KEY=
# From the Stripe webhook endpoint (stripe listen / dashboard). Required for the
# /api/stripe/webhook to accept events.
STRIPE_WEBHOOK_SECRET=

# Admin gate — required in production to access /admin. Rotate by changing it.
ADMIN_PASSWORD=

# Transactional email (Resend). Without RESEND_API_KEY, emails are skipped
# (the audit still runs). EMAIL_FROM must be a verified sender on your domain.
RESEND_API_KEY=
EMAIL_FROM=Finded <hello@finded.com>

# Public site URL used to build report links in emails (no trailing slash).
NEXT_PUBLIC_SITE_URL=https://finded.vercel.app
