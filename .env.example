# Supabase (Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=        # server-only secret; bypasses RLS

# AI providers — at least one required; the audit runs with whichever keys exist
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
PERPLEXITY_API_KEY=

# Inngest — the audit pipeline runs on Inngest.
# Local dev: leave blank and run `npx inngest-cli@latest dev`.
# Production: set both from the Inngest dashboard.
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Protects the cron endpoints (/api/queue/process, /api/monitoring/run).
# Generate: openssl rand -hex 32  — required in production.
CRON_SECRET=
